# Agentic Research Paper Evaluator — Environment Variables
# Copy this file to .env and fill in your API key

# ── LLM Provider (Required) ──────────────────────────────────────────────────

# OpenAI API key  →  https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-openai-key-here

# Model used by all CrewAI agents
PRIMARY_MODEL=gpt-4o-mini

# ── Token Management ─────────────────────────────────────────────────────────

# Max tokens per LLM call (assignment requirement: ≤ 16000)
MAX_TOKENS_PER_CALL=16000

# Overlap tokens when chunking long texts
CHUNK_OVERLAP=200

# ── Storage ───────────────────────────────────────────────────────────────────

# Local directory for caching downloaded arXiv PDFs
CACHE_DIR=./cache/papers

# ── Windows fix ───────────────────────────────────────────────────────────────

# Prevents charmap crash from emoji in CrewAI verbose output on Windows
PYTHONIOENCODING=utf-8
